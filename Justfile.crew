# Big Bang Crew — consumer recipes
# Imported by your main Justfile via `import 'Justfile.crew'`
# Updates ship via `Skill(bigbang-crew-agents:setup)` re-running

set positional-arguments

# List the 13 personas with their roles
list-personas:
    @echo "13 personas in the bigbang-crew:"
    @echo "  🧠 sheldon    — Orchestrator / Router"
    @echo "  📋 leonard    — Tech Lead / Decomposer"
    @echo "  🔧 howard     — Builder / Chaos Engineer"
    @echo "  🎨 raj        — Design Voice / A11y"
    @echo "  🗃️  leslie     — Data Platform"
    @echo "  🔬 amy        — Research Analyst"
    @echo "  🧪 bernadette — Reliability Engineer"
    @echo "  📚 stuart     — Integrations / Ops"
    @echo "  🔍 beverly    — Review Gate / CI-CD"
    @echo "  🚨 janine     — Incident Commander"
    @echo "  💬 penny      — Product Translator / UX"
    @echo "  🎓 drk        — Senior Architect / Billing"
    @echo "  📺 arthur     — Knowledge Archivist"

# Launch a persona-locked claude session (e.g. `just crew sheldon -p "ping"`)
crew PERSONA *ARGS:
    BIGBANG_PERSONA_LOCK={{PERSONA}} claude "$@"

# Initialize a coordination scratch directory for a new session/scope
scratch-init SCOPE:
    @mkdir -p .scratch/{{SCOPE}}/hand-off
    @echo "Created .scratch/{{SCOPE}}/hand-off/ — ready for handoff packets"

# Wipe the entire .scratch/ folder (asks for confirmation)
scratch-clean:
    #!/usr/bin/env bash
    if [ ! -d .scratch ]; then
      echo "No .scratch/ to clean."
      exit 0
    fi
    read -p "Delete .scratch/ and all contents? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
      rm -rf .scratch
      mkdir -p .scratch
      touch .scratch/.gitkeep
      echo "Wiped. .scratch/ recreated empty with .gitkeep."
    else
      echo "Cancelled."
    fi
